{
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/clean", "destination": "/api/clean" },
    { "source": "/api/verify", "destination": "/api/verify" },
    { "source": "/api/intext", "destination": "/api/intext" }
  ]
}
